      "required": true
    },
    "faqItems": {
      "type": "component",
      "repeatable": true,
      "component": "faq.faq-item"
    },
    "ctaHeading": {
      "type": "text",
      "required": true
    },
    "ctaBackgroundImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "ctaEyebrow": {
      "type": "string",
      "required": false
    },
    "ctaButtonText": {
      "type": "string",
      "required": false
    },
    "ctaButtonLink": {
      "type": "string",
      "required": false
    }
