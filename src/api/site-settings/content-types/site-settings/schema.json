{
  "kind": "singleType",
  "collectionName": "site_settings_entries",
  "info": {
    "singularName": "site-settings",
    "pluralName": "site-settings-entries",
    "displayName": "Site Settings",
    "description": "Global header, footer, and social link settings"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "headerLogo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "headerButtonText": {
      "type": "string",
      "required": true
    },
    "headerButtonLink": {
      "type": "string",
      "required": true
    },
    "footerLogo": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images", "files", "videos", "audios"]
    },
    "email": {
      "type": "email",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": false
    },
    "facebookUrl": {
      "type": "string",
      "required": false
    },
    "instagramUrl": {
      "type": "string",
      "required": false
    }
  }
}
